{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "life-app",
  "compatibility_date": "2025-04-04",
  "main": "./workers/app.ts",
  "pages_build_output_dir": "build/client",
  "assets": {
    "directory": "./build/client",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}